---
import Base from '../../layouts/base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import viridianData from '../../data/viridian.json';
import metaData from '../../data/viridian-meta.json';

const base = import.meta.env.BASE_URL;

const products = Object.entries(viridianData).map(([slug, product]) => ({
  slug,
  ...product,
  meta: metaData[slug as keyof typeof metaData],
  lowestPrice: Math.min(...product.variants.map(v => parseFloat(v.price))),
}));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Viridian Supplements at Beanfreaks Cardiff',
  description: 'Viridian vitamins, minerals and herbal supplements stocked at Beanfreaks health food shops in Cardiff.',
  url: 'https://www.beanfreaks.com/viridian/',
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.title,
    url: `https://www.beanfreaks.com/viridian/${p.slug}/`,
  })),
};
---
<head>
  <link rel="canonical" href="https://www.beanfreaks.com/viridian/" />
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
</head>
<Base
  title="Viridian Supplements Cardiff | Buy In Store | Beanfreaks"
  description="Authorised Viridian stockist in Cardiff. Full range of Viridian vitamins, minerals, probiotics and herbal supplements available in store at Roath, Canton and the Royal Arcade."
>

  <!-- Hero -->
  <section class="bg-cream">
    <div class="container-bf py-12 sm:py-16">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="pill-bf bg-ink/5 text-ink">Authorised stockist · Cardiff</p>
          <h1 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl">
            Viridian supplements in Cardiff
          </h1>
          <p class="mt-4 text-muted">
            We've stocked Viridian for years across our three Cardiff stores. Their commitment to 100% active
            ingredients, full formula transparency and UK manufacturing makes them one of the few brands we
            recommend without qualification. No fillers, no hype, no palm oil.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-primary" href="#products">Browse the range</a>
            <a class="btn-ghost" href={base + 'supplements/'}>All supplements</a>
          </div>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="pill-bf bg-ink/5 text-ink">UK made</span>
            <span class="pill-organic">100% active ingredients</span>
            <span class="pill-vegan">Vegan options</span>
          </div>
        </div>
        <div class="card-bf overflow-hidden bg-white shadow-none">
          <div class="flex h-64 items-center justify-center p-12 sm:h-80">
            <img
              src={base + 'img/brands/viridian.png'}
              alt="Viridian Nutrition"
              class="max-h-32 w-auto object-contain"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Viridian -->
  <section class="bg-paper">
    <div class="container-bf py-12 sm:py-16">
      <SectionHeader
        kicker="Why we chose them"
        title="What makes Viridian different"
        lead="A lot of supplement brands make similar claims. Viridian backs them up."
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="card-bf p-6">
          <h3 class="font-extrabold">100% active ingredients</h3>
          <p class="mt-2 text-sm text-muted">
            No magnesium stearate, no silicon dioxide, no cellulose fillers. Every capsule contains
            only what's on the label — the active nutrient and nothing else.
          </p>
        </div>
        <div class="card-bf p-6">
          <h3 class="font-extrabold">Made in the UK</h3>
          <p class="mt-2 text-sm text-muted">
            Formulated and manufactured in Warwickshire. Full traceability on all raw materials,
            with third-party testing for purity and potency.
          </p>
        </div>
        <div class="card-bf p-6">
          <h3 class="font-extrabold">Ethical sourcing</h3>
          <p class="mt-2 text-sm text-muted">
            No GMO, no palm oil, no animal testing. Packaging is fully recyclable. A certified
            B Corporation and a long-term partner of the Countryside Foundation for Education.
          </p>
        </div>
        <div class="card-bf p-6">
          <h3 class="font-extrabold">Transparent formulas</h3>
          <p class="mt-2 text-sm text-muted">
            Every ingredient and its source is disclosed. You know exactly what form of magnesium,
            what type of B12, and where each nutrient comes from.
          </p>
        </div>
        <div class="card-bf p-6">
          <h3 class="font-extrabold">Vegan-first range</h3>
          <p class="mt-2 text-sm text-muted">
            The majority of Viridian products are suitable for vegans — including their D3 range,
            which uses lichen-derived cholecalciferol rather than lanolin.
          </p>
        </div>
        <div class="card-bf p-6">
          <h3 class="font-extrabold">Expert advice in store</h3>
          <p class="mt-2 text-sm text-muted">
            Our staff know the Viridian range well. If you're not sure which product or size is right
            for you, come in and ask — we won't oversell.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section id="products" class="bg-cream">
    <div class="container-bf py-12 sm:py-16">
      <SectionHeader
        kicker="Our top sellers"
        title="Viridian products we stock"
        lead="Our 20 most consistently stocked Viridian lines across Roath, Canton and the Royal Arcade."
      />
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {products.map(p => (
          <a href={base + 'viridian/' + p.slug + '/'} class="card-bf group block overflow-hidden hover:border-leaf/40 transition-colors">
            <div class="bg-white">
              <img
                src={p.image}
                alt={p.title}
                class="h-44 w-full object-contain p-6 transition duration-300 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>
            <div class="p-4">
              <span class="pill-organic text-xs">{p.meta.category}</span>
              <h2 class="mt-2 text-sm font-extrabold leading-snug">{p.title}</h2>
              <p class="mt-1 text-sm font-semibold text-leaf">From £{p.lowestPrice.toFixed(2)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Find us -->
  <section class="bg-paper">
    <div class="container-bf py-12 sm:py-16">
      <SectionHeader
        kicker="In store"
        title="Where to find Viridian in Cardiff"
        lead="The full range is split across our three stores. The Royal Arcade has the deepest selection — Roath and Canton carry our top sellers."
      />
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <a href={base + 'roath/'} class="card-bf block p-6 hover:border-leaf/40 transition-colors">
          <h3 class="font-extrabold">Roath</h3>
          <p class="mt-1 text-sm text-muted">95 Albany Road, CF24 3LP</p>
          <p class="mt-1 text-xs text-muted">Mon–Sat 9am–5.30pm</p>
          <p class="mt-3 text-xs text-leaf font-semibold">Top sellers stocked →</p>
        </a>
        <a href={base + 'canton/'} class="card-bf block p-6 hover:border-leaf/40 transition-colors">
          <h3 class="font-extrabold">Canton</h3>
          <p class="mt-1 text-sm text-muted">124 Cowbridge Road East, CF11 9DX</p>
          <p class="mt-1 text-xs text-muted">Mon–Sat 9am–5.30pm</p>
          <p class="mt-3 text-xs text-leaf font-semibold">Top sellers stocked →</p>
        </a>
        <a href={base + 'royal/'} class="card-bf block p-6 hover:border-leaf/40 transition-colors">
          <h3 class="font-extrabold">Royal Arcade</h3>
          <p class="mt-1 text-sm text-muted">8 Royal Arcade, CF10 1AE</p>
          <p class="mt-1 text-xs text-muted">Mon–Sat 9.30am–5pm</p>
          <p class="mt-3 text-xs text-leaf font-semibold">Full range available →</p>
        </a>
      </div>
    </div>
  </section>

</Base>
